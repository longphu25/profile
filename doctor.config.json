{
  "$schema": "https://react.doctor/schema/config.json",
  "lint": true,
  "deadCode": false,
  "verbose": false,
  "blocking": "none",
  "respectInlineDisables": true,
  "adoptExistingLintConfig": true,
  "projects": ["src", "plugins"],
  "ignore": {
    "files": [
      "node_modules/**",
      "dist/**",
      "dist-solana/**",
      "build/**",
      "coverage/**",
      ".cache/**",
      "public/**",
      ".kiro/**",
      ".agents/**",
      ".main-agent/**",
      ".grok/**",
      "docs/**",
      "apps/**",
      "packages/**",
      ".github/**",
      "tests/**",
      "**/*.d.ts",
      "**/*.test.{ts,tsx,js,jsx}",
      "**/*.spec.{ts,tsx,js,jsx}",
      "plugins/*/pkg/**",
      "plugins/*/wasm/**",
      "workers/**",
      "contracts/**",
      "scripts/**",
      "vite.config.ts",
      "vite.config.*.ts",
      "eslint.config.js",
      "commitlint.config.ts",
      "playwright.config.ts",
      "lint-staged.config.mjs"
    ],
    "rules": [
      "react-hooks-js/todo",
      "react-doctor/react-compiler-no-manual-memoization",
      "react-hooks-js/static-components",
      "react-hooks-js/preserve-manual-memoization",
      "react-doctor/jsx-no-undef"
    ],
    "tags": []
  },
  "rules": {
    "react-hooks-js/set-state-in-effect": "warn",
    "react-hooks-js/purity": "warn",
    "react-hooks-js/immutability": "warn"
  }
}