# Predict Club — on-chain RPC configuration
#
# Public fullnode (fullnode.testnet.sui.io) does NOT send CORS headers, so
# direct browser calls fail in production. In dev, a Vite proxy (/api/sui-testnet)
# handles this automatically. For production, point these at a CORS-friendly RPC.

# Testnet JSON-RPC endpoint (CORS-friendly). Examples:
#   Blockvision : https://sui-testnet-endpoint.blockvision.org/v1/<API_KEY>
#   Shinami     : https://api.shinami.com/sui/node/v1/<API_KEY>
#   Ankr        : https://rpc.ankr.com/sui_testnet/<API_KEY>
# Leave unset in dev to use the built-in Vite proxy.
VITE_TESTNET_RPC_URL=

# Optional: WebSocket endpoint that supports suix_subscribeEvent.
# Public fullnodes have removed WS subscriptions, so leave empty unless you have
# a subscription-capable provider. When empty, the app uses REST polling only.
VITE_TESTNET_WS_URL=

# Dev tooling (dev server only; tree-shaken from production builds).
# Both OFF by default because each adds main-thread overhead in dev.
#   react-scan: render-performance outlines + profiling (heavy with many components)
#   react-grab: copy any UI element with its source context for agents
# Set to true to enable, then restart `npm run dev`.
VITE_DEV_REACT_SCAN=false
VITE_DEV_REACT_GRAB=false
